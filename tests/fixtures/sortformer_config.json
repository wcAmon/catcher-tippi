    "n_heads": 8,
    "att_context_size": [
      -1,
      -1
    ],
    "att_context_style": "regular",
    "xscaling": true,
    "untie_biases": true,
    "pos_emb_max_len": 5000,
    "conv_kernel_size": 9,
    "conv_norm_type": "batch_norm",
