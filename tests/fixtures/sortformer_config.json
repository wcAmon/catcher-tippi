    "reduction": "mean"
  },
  "lr": 0.0001,
  "optim": {
    "name": "adamw",
    "lr": 0.0001,
    "betas": [
      0.9,
      0.98
    ],
    "weight_decay": 0.001,
    "sched": {
      "name": "InverseSquareRootAnnealing",
      "warmup_steps": 3000,
      "warmup_ratio": null,
      "min_lr": 1e-06
    }
  },
  "target": "nemo.collections.asr.models.sortformer_diar_models.SortformerEncLabelModel",
